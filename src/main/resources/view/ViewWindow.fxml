<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.stage.Stage?>

<fx:root resizable="false" title="View Gamer" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17"
         xmlns:fx="http://javafx.com/fxml/1">
    <icons>
        <Image url="@/images/blockbook_icon.png"/>
    </icons>
    <scene>
        <Scene width="760.0" height="320.0">
            <stylesheets>
                <URL value="@DarkTheme.css"/>
                <URL value="@Extensions.css"/>
            </stylesheets>
            <StackPane styleClass="pane-with-border">
                <ScrollPane fx:id="cardScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                    <content>
                        <StackPane fx:id="cardPlaceholder" alignment="TOP_LEFT">
                            <padding>
                                <Insets top="0" right="0" bottom="0" left="0"/>
                            </padding>
                        </StackPane>
                    </content>
                </ScrollPane>
            </StackPane>
        </Scene>
    </scene>
</fx:root>
