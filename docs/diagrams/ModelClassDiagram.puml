@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyBlockBook" as ReadOnlyBlockBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class BlockBook
Class ModelManager
Class UserPrefs

Class UniqueGamerList
Class UniqueGroupList
Class Gamer
Class GamerTag
Class Email
Class Name
Class Phone
Class Group
Class Server
Class Favourite
Class Country
Class Region
Class Note

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

BlockBook .up.|> ReadOnlyBlockBook

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyBlockBook
ModelManager -left-> "1" BlockBook
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

BlockBook *--> "1" UniqueGamerList
BlockBook *--> "1" UniqueGroupList
UniqueGamerList --> "~* all" Gamer
UniqueGroupList --> "~* all" Group
Gamer *--> "0..1" Name
Gamer *--> "1" GamerTag
Gamer *--> "0..1" Phone
Gamer *--> "0..1" Email
Gamer *--> "0..1" Server
Gamer *--> "0..1" Favourite
Gamer *--> "0..1" Country
Gamer *--> "0..1" Region
Gamer *--> "0..1" Note
Gamer *--> "*" Group

Gamer -[hidden]up--> I
UniqueGamerList -[hidden]right-> I

Name -[hidden]right-> GamerTag
GamerTag -[hidden]right-> Phone
Phone -[hidden]right-> Email
Server -[hidden]right-> Favourite
Favourite -[hidden]right-> Country
Country -[hidden]right-> Region
Region -[hidden]right-> Note

ModelManager --> "~* filtered" Gamer
@enduml

